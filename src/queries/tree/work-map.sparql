# Workspace work map: active charters and actions as portable tree bindings.
# Contract: every row has ?id, ?name, ?kind; roots omit ?parent and every
# bound ?parent identifies another row in this same result.

PREFIX actions: <https://clearhead.us/vocab/actions/v4#>
PREFIX bfo: <http://purl.obolibrary.org/obo/>
PREFIX cco: <https://www.commoncoreontologies.org/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ws: <https://clearhead.us/vocab/workspace/v1#>

SELECT ?id ?parent ?name ?kind ?status ?priority ?source_file ?source_line ?charter_root WHERE {
    GRAPH ?g {
        ?workspace a ws:Workspace ; ws:charterRoot ?charter_root .
        {
            ?id a actions:Charter ; rdfs:label ?name .
            BIND("charter" AS ?kind)
            OPTIONAL { ?parent a actions:Charter ; actions:hasSubCharter ?id }
            OPTIONAL { ?id actions:hasCharterState ?status }
            OPTIONAL { ?id ws:hasSourceFile ?source_file }
        }
        UNION
        {
            ?id a actions:Action ;
                rdfs:label ?name ;
                cco:ont00001868 ?raw_status .
            FILTER(?raw_status != actions:Completed && ?raw_status != actions:Cancelled)
            BIND("action" AS ?kind)
            BIND(STRAFTER(STR(?raw_status), "#") AS ?status)

            OPTIONAL {
                ?id bfo:BFO_0000050 ?action_parent .
                ?action_parent a actions:Action .
            }
            OPTIONAL {
                ?charter a actions:Charter ; bfo:BFO_0000051 ?id .
            }
            OPTIONAL {
                ?plan_charter a actions:Charter ; bfo:BFO_0000051 ?plan .
                ?plan cco:ont00001942 ?id .
            }
            BIND(COALESCE(?action_parent, ?charter, ?plan_charter) AS ?parent)

            OPTIONAL { ?id actions:hasPriority ?priority }
            OPTIONAL { ?id ws:hasSourceFile ?source_file }
            OPTIONAL { ?id ws:hasSourceLine ?source_line }
        }
    }
}
ORDER BY ?kind ?name
